        <artifactId>maven-fluido-skin</artifactId>
        <version>${fluido-skin.version}</version>
    </skin>

    <custom>
        <fluidoSkin>
            <gitHub>
                <projectId>heitkergm/finance</projectId>
                <ribbonOrientation>right</ribbonOrientation>
                <ribbonColor>black</ribbonColor>
